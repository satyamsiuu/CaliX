# Google OAuth credentials (required)
# Create a project at https://console.cloud.google.com/apis/credentials
# Enable the Google Calendar API, create an OAuth 2.0 Client ID (Web application)
# Add http://localhost:3000/api/auth/callback/google as an authorized redirect URI
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth (required)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Database Encryption
DATABASE_ENCRYPTION_KEY=

# Groq API key (required for AI Mode)
# Get one at https://console.groq.com
GROQ_API_KEY=

# Database (Neon or SQLite/Postgres)
DATABASE_URL=
